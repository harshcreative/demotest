  <% Dim user_agent, mobile_browser, Regex, match, mobile_agents, mobile_ua, i, size
    user_agent=Request.ServerVariables("HTTP_USER_AGENT") mobile_browser=0 Set Regex=New RegExp With Regex
    .Pattern="(up.browser|up.link|mmp|symbian|smartphone|midp|wap|phone|windows ce|pda|mobile|mini|palm)"
    .IgnoreCase=True .Global=True End With match=Regex.Test(user_agent) If match Then mobile_browser=mobile_browser+1 If
    InStr(Request.ServerVariables("HTTP_ACCEPT"), "application/vnd.wap.xhtml+xml" ) Or Not
